      "modified": "1970-01-01T00:00:00.007Z",
      "body": [
        {
          "type": "TextualBody",
          "value": "**Upper-left Voynichese block.** A solid paragraph of running text in the manuscript's untranslated script. Word lengths cluster in the 4-6 character range; spacing is regular; line endings show the same statistical asymmetry that researchers cite as evidence of underlying language.",
          "purpose": "commenting"
        }
      ],
      "archie:hasHistory": "https://archie.demo/voynich/annotations/history/0000000007N826AW6AV8MQ8AD5.json"
    },
