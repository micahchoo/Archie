      "body": [
        {
          "type": "TextualBody",
          "value": "**The marginal stars.** A column of small six- and eight-pointed star glyphs runs down the left margin, one per line of text. These margin-stars occur on several manuscript pages and may mark verse divisions, paragraph beginnings, or list items — their function is unsettled.",
          "purpose": "commenting"
        }
      ],
      "archie:hasHistory": "https://archie.demo/voynich/annotations/history/000000000Q26J03EAEAG41W93K.json"
