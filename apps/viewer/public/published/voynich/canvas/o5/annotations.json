        {
          "type": "TextualBody",
          "value": "**Voynichese — a close-up text sample.** Around 35 000 characters survive across 240 leaves, in a single distinctive hand. The script behaves statistically like a natural language (Zipf-like word frequency, syllabic structure) but no decipherment has held up to scrutiny.",
          "purpose": "commenting"
        }
      ],
      "archie:hasHistory": "https://archie.demo/voynich/annotations/history/000000000PE0PNXQ8CR23H3BF0.json"
    },
