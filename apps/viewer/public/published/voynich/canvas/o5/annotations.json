      "modified": "1970-01-01T00:00:00.024Z",
      "body": [
        {
          "type": "TextualBody",
          "value": "**First paragraph.** The first five visible lines show typical Voynichese: words of 4-6 characters, regular spacing, the recurring \"daiin\" pattern of three short ascenders. The first character of the paragraph is taller than its neighbours — a rubrication-style opening cap shared with Latin manuscript conventions.",
          "purpose": "commenting"
        }
      ],
      "archie:hasHistory": "https://archie.demo/voynich/annotations/history/000000000RK8F9FH8PGRMBYEEV.json"
    },
