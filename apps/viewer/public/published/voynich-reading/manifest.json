      "type": "Range",
      "label": {
        "none": [
          "Herbal"
        ]
      },
      "summary": {
        "none": [
          "The book opens as a herbal: a plant to a page, text flowing around the drawing. None of these plants can be named with certainty — some look observed, some invented — and the writing has never been read."
        ]
      },
      "items": [
        {
          "id": "https://micahchoo.github.io/Archie/viewer/published/voynich-reading/canvas/o1",
          "type": "Canvas"
