      "label": {
        "none": [
          "Cosmological"
        ]
      },
      "summary": {
        "none": [
          "The largest spread in the book unfolds into nine medallions joined by causeways, with castle-like and map-like forms. Whether it charts real places or imagined ones is part of what the page refuses to settle."
        ]
      },
