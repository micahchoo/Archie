      "label": {
        "none": [
          "Balneological"
        ]
      },
      "summary": {
        "none": [
          "Small bathing figures move through green networks of pipes and basins. The script shifts character here — measurably a different system than the herbal — as if a second voice took up the pen."
        ]
      },
      "items": [
        {
          "id": "https://micahchoo.github.io/Archie/viewer/published/voynich-reading/canvas/o8",
