      "type": "Range",
      "label": {
        "none": [
          "Astronomical"
        ]
      },
      "summary": {
        "none": [
          "The pages widen into fold-out wheels of Sun, Moon, and stars, each star tied to a small labelled word. Conventional zodiac figures appear, but the labels around them stay closed to us."
        ]
      },
      "items": [
