          "value": "t=250,296"
        }
      },
      "modified": "1970-01-01T00:00:00.048Z",
      "body": [
        {
          "type": "TextualBody",
          "value": "The reading ends without resolving. That the ear can't decide between language and noise is the manuscript's whole condition — undeciphered, even when sounded.",
          "purpose": "commenting"
        }
      ],
      "motivation": "commenting",
      "archie:hasHistory": "https://micahchoo.github.io/Archie/viewer/published/voynich-reading/annotations/history/000000001GRT9MVKB3S28A70M0.json"
    },
    {
      "id": "https://micahchoo.github.io/Archie/viewer/published/voynich-reading/annotations/000000001KX2F342E3KYEVTEC0/v1",
      "type": "Annotation",
      "target": "https://micahchoo.github.io/Archie/viewer/published/voynich-reading/canvas/o12",
      "modified": "1970-01-01T00:00:00.051Z",
      "body": [
        {
          "type": "TextualBody",
          "value": "This note is about the whole recording, not any moment in it: the Kryptogramm sonification reads folio 18v end to end. Whether you hear enciphered speech, a grille's rhythm, or an unknown real language is the manuscript's whole condition — so the claim attaches to the track entire.",
          "purpose": "commenting"
        }
      ],
      "motivation": "commenting",
      "archie:hasHistory": "https://micahchoo.github.io/Archie/viewer/published/voynich-reading/annotations/history/000000001KX2F342E3KYEVTEC0.json"
