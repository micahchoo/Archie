      "modified": "1970-01-01T00:00:00.047Z",
      "body": [
        {
          "type": "TextualBody",
          "value": "Here the “words” cluster like labels. Cryptanalysts attacked exactly such short tokens as cribs (cipher); Rugg's tables emit them just as readily (grille); Bax read them as proper names (abjad).",
          "purpose": "commenting"
        }
      ],
      "archie:hasHistory": "https://archie.demo/voynich-reading/annotations/history/000000001FK76A9MAM26V81JBD.json"
    },
