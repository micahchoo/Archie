          "value": "t=45,80"
        }
      },
      "modified": "1970-01-01T00:00:00.046Z",
      "body": [
        {
          "type": "TextualBody",
          "value": "A repeated cadence surfaces. Under the abjad reading this resembles a root-and-pattern morphology (Bax); under the grille reading it is the predictable repetition the prefix/stem/suffix tables force; under the cipher reading it is enciphered structure showing through.",
          "purpose": "commenting"
        }
      ],
      "archie:hasHistory": "https://archie.demo/voynich-reading/annotations/history/000000001EETEW0M9M4GJ809T6.json"
    },
