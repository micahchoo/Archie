---
// SINGLE-layout exhibit reader — "The Rosettes" (only o9, the f85v–86r foldout). Mirrors voynich.astro
// but points ExhibitView at the voynich-rosettes slug; resolveLayout infers single (1 object, no sections).
import ExhibitView from "../components/ExhibitView.svelte";
import "../tokens.css";
import "@annotorious/openseadragon/annotorious-openseadragon.css";
import "@annotorious/plugin-tools/annotorious-plugin-tools.css";
import "../markers.css"; // A2 + stroke-over-stroke marker styling — must load AFTER Annotorious CSS
import "../atmosphere.css"; // Soft Static reskin layer (warm paper, soft-focus blur depth, rounded, grain)
import { ogImageFor } from "../og-image.js";
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
const ogImage = ogImageFor("voynich-rosettes"); // exhibit cover, absolute (ADR-0013)
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={base + "favicon.svg"} />
    <title>The Rosettes — Archie</title>
    <!-- Shareability meta (GOAL §5: og-tags are table-stakes for exhibit publishers — mulch product-research).
         og:image needs an absolute deploy origin — deferred (seed). -->
    <meta name="description" content="A single-folio deep-zoom study: the Rosettes foldout (f85v–86r), the largest spread in MS 408, read three ways — cipher, hoax, and natural language — over one canvas." />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Archie" />
    <meta property="og:title" content="The Rosettes" />
    <meta property="og:description" content="A single-folio deep-zoom study: the Rosettes foldout (f85v–86r), the largest spread in MS 408, read three ways — cipher, hoax, and natural language — over one canvas." />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- schema.org JSON-LD (GOAL §5a ⑤): typed structured data so published exhibits are
         machine-readable to search engines — same copy as the og tags. -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({"@context": "https://schema.org", "@type": "VisualArtwork", "name": "The Rosettes", "description": "A single-folio deep-zoom study: the Rosettes foldout (f85v–86r), the largest spread in MS 408, read three ways — cipher, hoax, and natural language — over one canvas.", "about": {"@type": "CreativeWork", "name": "Voynich manuscript (Beinecke MS 408)"}, "license": "https://creativecommons.org/publicdomain/mark/1.0/"})} />
    <link rel="stylesheet" href={base + "fonts/fonts.css"} />
  </head>
  <body style="margin: 0">
    <!-- client:only — OSD touches `document` at import, so the reader is browser-only (no SSR). -->
    <ExhibitView client:only="svelte" slug="voynich-rosettes" />
  </body>
</html>
