---
// Archie Viewer — the single client-routed shell (CONTEXT §"Local view loop": "one smart hall").
// Was a hardcoded static gallery + per-sample exhibit pages; now ONE shell that hash-routes the
// Gallery (from exhibits.json) and any exhibit at runtime — renders an arbitrary published Library
// with no per-exhibit code. CSS for BOTH surfaces loads here (the shell renders exhibits too).
import ViewerShell from "../components/ViewerShell.svelte";
import "../tokens.css";
import "@annotorious/openseadragon/annotorious-openseadragon.css";
import "@annotorious/plugin-tools/annotorious-plugin-tools.css";
import "../markers.css"; // A2 + stroke-over-stroke marker styling — must load AFTER Annotorious CSS
import "../atmosphere.css"; // Soft Static atmosphere (gradient ground + grain + bloom) — must load LAST (wins source order)
import { ogImageFor } from "../og-image.js";
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
const ogImage = ogImageFor(null); // the gallery page wears the brand card (ADR-0013)
// Canonical builds (build-gh-pages.sh sets PUBLIC_CANONICAL_ORIGIN) bake their expected origin
// into the shell so a drifted deploy SURFACES (ADR-0013 observability rider).
const expectedBase = process.env.PUBLIC_CANONICAL_ORIGIN; // frontmatter runs in Node at build — process.env is the reliable channel (carries origin+viewerPath, hence "base")
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={base + "favicon.svg"} />
    <title>Archie</title>
    <!-- Shareability meta (GOAL §5: og-tags are table-stakes for exhibit publishers — mulch product-research).
         og:image needs an absolute deploy origin — deferred (seed). -->
    <meta name="description" content="A contested manuscript read more than one way — Beinecke MS 408, the same undeciphered marks read three ways across three exhibits." />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Archie" />
    <meta property="og:title" content="The Archie Library" />
    <meta property="og:description" content="A contested manuscript read more than one way — Beinecke MS 408, the same undeciphered marks read three ways across three exhibits." />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- schema.org JSON-LD (GOAL §5a ⑤): typed structured data so published exhibits are
         machine-readable to search engines — same copy as the og tags. -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({"@context": "https://schema.org", "@type": "CollectionPage", "name": "The Archie Library", "description": "A contested manuscript read more than one way — Beinecke MS 408, the same undeciphered marks read three ways across three exhibits."})} />
    <link rel="stylesheet" href={base + "fonts/fonts.css"} />
  </head>
  <body style="margin: 0">
    <!-- client:only — OSD touches `document` at import, so the shell is browser-only (no SSR). -->
    <ViewerShell client:only="svelte" {expectedBase} />
  </body>
</html>
