---
// NARRATIVE-layout exhibit reader — "Reading the Unreadable" (all folios + the sounded page, the 6-beat
// spine). Mirrors voynich.astro but points ExhibitView at the voynich-reading slug; resolveLayout infers
// narrative (the round-tripped sections), so it renders the NarrativeReader (spine + readings legend).
import ExhibitView from "../components/ExhibitView.svelte";
import "../tokens.css";
import "@annotorious/openseadragon/annotorious-openseadragon.css";
import "@annotorious/plugin-tools/annotorious-plugin-tools.css";
import "../markers.css"; // A2 + stroke-over-stroke marker styling — must load AFTER Annotorious CSS
import "../atmosphere.css"; // Soft Static reskin layer (warm paper, soft-focus blur depth, rounded, grain)
import { ogImageFor } from "../og-image.js";
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
const ogImage = ogImageFor("voynich-reading"); // exhibit cover, absolute (ADR-0013)
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={base + "favicon.svg"} />
    <title>Reading the Unreadable — Archie</title>
    <!-- Shareability meta (GOAL §5: og-tags are table-stakes for exhibit publishers — mulch product-research).
         og:image needs an absolute deploy origin — deferred (seed). -->
    <meta name="description" content="A narrative walk through the six divisions of MS 408 — herbal to recipes — pausing on each to read the same undeciphered marks three ways, ending on a page sounded aloud." />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Archie" />
    <meta property="og:title" content="Reading the Unreadable" />
    <meta property="og:description" content="A narrative walk through the six divisions of MS 408 — herbal to recipes — pausing on each to read the same undeciphered marks three ways, ending on a page sounded aloud." />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- schema.org JSON-LD (GOAL §5a ⑤): typed structured data so published exhibits are
         machine-readable to search engines — same copy as the og tags. -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({"@context": "https://schema.org", "@type": "CreativeWork", "name": "Reading the Unreadable", "description": "A narrative walk through the six divisions of MS 408 — herbal to recipes — pausing on each to read the same undeciphered marks three ways, ending on a page sounded aloud.", "about": {"@type": "CreativeWork", "name": "Voynich manuscript (Beinecke MS 408)"}, "license": "https://creativecommons.org/publicdomain/mark/1.0/"})} />
    <link rel="stylesheet" href={base + "fonts/fonts.css"} />
  </head>
  <body style="margin: 0">
    <!-- client:only — OSD touches `document` at import, so the reader is browser-only (no SSR). -->
    <ExhibitView client:only="svelte" slug="voynich-reading" />
  </body>
</html>
