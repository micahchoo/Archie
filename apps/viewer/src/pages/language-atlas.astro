---
// Exhibit reader page (the published read-only exhibit). Reached from the Gallery (index).
// Renders via ExhibitView — the layout orchestrator (Grid overview ⇄ object Reader).
import ExhibitView from "../components/ExhibitView.svelte";
import "../tokens.css";
import "@annotorious/openseadragon/annotorious-openseadragon.css";
import "@annotorious/plugin-tools/annotorious-plugin-tools.css";
import "../markers.css"; // A2 + stroke-over-stroke marker styling — must load AFTER Annotorious CSS
import "../atmosphere.css"; // Soft Static reskin layer (warm paper, soft-focus blur depth, rounded, grain)
import { ogImageFor } from "../og-image.js";
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
const ogImage = ogImageFor("language-atlas"); // exhibit cover, absolute (ADR-0013)
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={base + "favicon.svg"} />
    <title>Where Languages Go Silent — Archie</title>
    <!-- Shareability meta (GOAL §5: og-tags are table-stakes for exhibit publishers — mulch product-research).
         og:image needs an absolute deploy origin — deferred (seed). -->
    <meta name="description" content="Eight map pages from UNESCO's Atlas of the World's Languages in Danger (2010) — every dot a language losing its speakers, read two ways: a linguist's census, and what the quiet means where it falls." />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Archie" />
    <meta property="og:title" content="Where Languages Go Silent" />
    <meta property="og:description" content="Eight map pages from UNESCO's Atlas of the World's Languages in Danger (2010) — every dot a language losing its speakers, read two ways: a linguist's census, and what the quiet means where it falls." />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- schema.org JSON-LD (GOAL §5a ⑤): typed structured data so published exhibits are
         machine-readable to search engines — same copy as the og tags. -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({"@context": "https://schema.org", "@type": "ImageGallery", "name": "Where Languages Go Silent", "description": "Eight map pages from UNESCO's Atlas of the World's Languages in Danger (2010), annotated with a linguist's reading and a community reading.", "about": {"@type": "CreativeWork", "name": "Atlas of the World's Languages in Danger (UNESCO, 2010)"}, "license": "https://creativecommons.org/licenses/by-sa/4.0/"})} />
    <link rel="stylesheet" href={base + "fonts/fonts.css"} />
  </head>
  <body style="margin: 0">
    <!-- client:only — OSD touches `document` at import, so the reader is browser-only (no SSR). -->
    <ExhibitView client:only="svelte" slug="language-atlas" />
  </body>
</html>
