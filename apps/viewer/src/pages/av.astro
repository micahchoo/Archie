---
// Reader page for the AV fixture — a Sound object read against its transcript (CONTEXT §81).
// No OSD/Annotorious CSS: the temporal MediaPlayer uses a native <audio> element, not a deep-zoom canvas.
import ExhibitView from "../components/ExhibitView.svelte";
import "../tokens.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>A Field Recording from Bidar — Archie</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Crimson+Text:ital,wght@0,400;0,600;1,400&family=Work+Sans:wght@400;500;600&family=JetBrains+Mono&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style="margin: 0">
    <!-- client:only — ExhibitView pulls browser-only deps; the player itself is plain <audio>. -->
    <ExhibitView client:only="svelte" slug="av" />
  </body>
</html>
