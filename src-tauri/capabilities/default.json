{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Archie Studio default capability — native filesystem (the TauriFsBridge surface) + folder dialog, scoped to the app-data dir and the user's home.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-remove",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }]
    }
  ]
}
